# Variáveis de Ambiente - Supabase

# Obtenha esses valores no seu projeto Supabase
# https://app.supabase.com/project/[seu-projeto]/settings/api

# URL pública do seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima pública (ANON_KEY)
NEXT_PUBLIC_SUPABASE_ANON_KEY=seu-anon-key-aqui
